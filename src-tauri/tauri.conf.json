{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BoostForge",
  "version": "0.1.0",
  "identifier": "com.boostforge.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "BoostForge",
        "width": 1200,
        "height": 800,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3QTgyRkZBNzg2OTEzRjYKUldUMkUybDQraStvbDAwRm9rZW5Hb3hoaTYxNUJWY05JcE1qM0xSSlJKQ2lEYytTMitxaUgwTUcK",
      "endpoints": [
        "https://github.com/Bogroliakiraly/boostforge/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "BoostForge",
    "category": "Utility",
    "shortDescription": "Trustworthy Windows gaming optimizer",
    "longDescription": "BoostForge optimizes Windows for gaming using only measurable, reversible and safe changes. No fake benchmarks, no placebo tweaks.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
